# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081,http://localhost:19006

# ─── PostgreSQL (pgvector) ───────────────────────────────────────────────────
POSTGRES_USER=passpath
POSTGRES_PASSWORD=passpath
POSTGRES_DB=passpath
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Used by Prisma. Inside docker-compose, host becomes "db".
DATABASE_URL=postgresql://passpath:passpath@localhost:5432/passpath?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Firebase Admin (identity provider) ──────────────────────────────────────
# From the Firebase service-account JSON. Keep the private key on a single line
# with literal \n escapes, or point FIREBASE_SERVICE_ACCOUNT_PATH at the file.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=

# ─── OpenAI (AI learning engine) ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536

# ─── Storage (S3 abstraction) ────────────────────────────────────────────────
STORAGE_DRIVER=s3                 # s3 | local
AWS_REGION=af-south-1
AWS_S3_BUCKET=passpath-assets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=                  # optional, for MinIO/local
STORAGE_LOCAL_DIR=./storage

# ─── Security ────────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60                 # seconds
RATE_LIMIT_LIMIT=120              # requests per TTL per IP

# ─── Dev-only demo auth ──────────────────────────────────────────────────────
# Enables POST /auth/dev-login (password login for demo accounts) and "dev:<id>"
# bearer tokens. IGNORED when NODE_ENV=production. Never enable in production.
ENABLE_DEV_AUTH=true
DEMO_PASSWORD=passpath-demo
